---
import ContactBar from "./ui/contact-bar";
import DarkTransition from "./ui/DarkTransition";
---

<DarkTransition client:only />
<div class="h-screen flex flex-col items-center justify-center gap-6" id="contact">
    <span
        class="pointer-events-none bg-linear-to-b from-purple-400 to-amber-500/80 bg-clip-text text-center text-8xl leading-none font-semibold text-transparent"
    >
        Let's connect
    </span>
    <p class="text-gray-400 text-lg max-w-md text-center">
        Got a project in mind, want to collaborate, or just want to say hi?
    </p>
    <a
        href="mailto:thatxliner@gmail.com"
        class="text-gray-300 hover:text-white transition-colors text-sm tracking-wide"
    >
        thatxliner@gmail.com
    </a>
    <ContactBar client:only />
</div>
