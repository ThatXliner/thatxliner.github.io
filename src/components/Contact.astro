---
import ContactBar from "./ui/contact-bar";
---

<div
    class="min-h-screen flex flex-col items-center justify-center gap-4 md:gap-6 px-6"
    id="contact"
>
    <span
        class="pointer-events-none bg-linear-to-b from-purple-400 to-amber-500/80 bg-clip-text text-center text-5xl sm:text-6xl md:text-8xl leading-none font-semibold text-transparent"
    >
        Let's connect
    </span>
    <p class="text-gray-400 text-base md:text-lg max-w-md text-center px-4">
        Got a project in mind, want to collaborate, or just want to say hi?
    </p>
    <a
        href="mailto:thatxliner@gmail.com"
        class="text-gray-300 hover:text-white transition-colors text-sm tracking-wide"
    >
        thatxliner@gmail.com
    </a>
    <ContactBar client:only />
</div>
