async function getRepoHomepage(repoName: string): Promise<string | null> {
    const token = import.meta.env.ASTRO_GITHUB_TOKEN;
    if (!token) return null;
    const res = await fetch("https://api.github.com/graphql", {
        method: "POST",
        headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${token}`,
        },
        body: JSON.stringify({
            query: `query { viewer { repository(name: "${repoName}") { homepageUrl } } }`,
        }),
    });
    if (!res.ok) return null;
    const json = await res.json();
    return json.data?.viewer?.repository?.homepageUrl || null;
}

